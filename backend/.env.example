# ── Server ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ──────────────────────────────────────────────
# Local:   mongodb://127.0.0.1:27017/templeconnect
# Atlas:   mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/templeconnect
MONGODB_URI=mongodb://127.0.0.1:27017/templeconnect

# ── JWT ──────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_STRING_64_CHARS
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ── File Upload ──────────────────────────────────────────
MAX_FILE_SIZE_MB=5
UPLOAD_DIR=uploads
